# Copy to stt.env and fill in. stt.env is git-ignored and holds your secrets.
# The interactive wrapper (run.sh) sources this; launchd uses the plist instead.

# Required for diarization (the pyannote model is gated). Create a READ token at
# https://hf.co/settings/tokens and accept the terms at
# https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# Route unsupported ops to CPU if you ever experiment with MPS (we default to CPU).
PYTORCH_ENABLE_MPS_FALLBACK=1

# --- Optional overrides ---
# STT_ASR_BACKEND=parakeet          # or "whisperx" (needs a separate venv)
# STT_NAMING_THRESHOLD=0.60         # cosine similarity to accept a voiceprint match
# STT_MOVE_AFTER_SUCCESS=1          # 0 to keep iCloud originals
# STT_WHISPERX_BIN=/path/to/whisperx-venv/bin/whisperx
# STT_WHISPER_MODEL=large-v3
