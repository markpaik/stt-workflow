# ============================================================
# PRIVACY: this pipeline handles recordings of real people.
# Everything derived from audio stays out of the repository.
# ============================================================

# Secrets — HuggingFace token and local settings
stt.env

# Voiceprints are BIOMETRIC data — never commit any of it
voiceprints/

# Real meeting content: audio, reference transcripts, QA material
qa/
*.m4a
*.wav
*.mp3
*.aiff
*.mp4
*.mov

# Runtime state (contains meeting names and processing history)
manifest.json
status.json
calibration.jsonl
rates.jsonl
logs/
work/
ab_out/
gui.out.log
gui.err.log

# Locks / flags / queued panel runs
queued_jobs.json
queued_jobs.lock
batch.lock
relabel.lock
status.lock
llm.lock
paused.flag
stopping.flag
relabel_pending.flag

# launchd plists are GENERATED by setup.sh with personal paths
com.*.plist

# Environments
.venv/
.venv-*/
__pycache__/
*.pyc

# macOS noise
.DS_Store
native/stt-recorder
